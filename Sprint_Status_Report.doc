<style>
    body {
        font-family: 'Segoe UI', 'Calibri', Arial, sans-serif;
        color: #333333;
        line-height: 1.5;
        margin: 0;
        padding: 40px;
    }
    .header-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 30px;
        border: none;
    }
    .header-title {
        font-size: 26pt;
        font-weight: bold;
        color: #1e3a8a;
        margin: 0;
        padding-bottom: 5px;
    }
    .header-subtitle {
        font-size: 14pt;
        color: #4b5563;
        margin: 0;
    }
    h1 {
        font-size: 18pt;
        color: #1e3a8a;
        border-bottom: 2px solid #3b82f6;
        padding-bottom: 6px;
        margin-top: 30px;
        margin-bottom: 15px;
    }
    h2 {
        font-size: 14pt;
        color: #2563eb;
        margin-top: 20px;
        margin-bottom: 10px;
    }
    table.status-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
        margin-bottom: 25px;
    }
    table.status-table th {
        background-color: #eff6ff;
        color: #1e3a8a;
        border: 1px solid #bfdbfe;
        padding: 10px 12px;
        font-weight: bold;
        text-align: left;
        font-size: 11pt;
    }
    table.status-table td {
        border: 1px solid #e2e8f0;
        padding: 10px 12px;
        font-size: 10pt;
        vertical-align: top;
    }
    .badge {
        display: inline-block;
        padding: 4px 8px;
        font-weight: bold;
        font-size: 9pt;
        border-radius: 4px;
        text-align: center;
    }
    .badge-green {
        background-color: #dcfce7;
        color: #15803d;
    }
    .badge-yellow {
        background-color: #fef9c3;
        color: #854d0e;
    }
    .badge-red {
        background-color: #fee2e2;
        color: #991b1b;
    }
    .bullet-bold {
        font-weight: bold;
        color: #1e3a8a;
    }
    .footer {
        margin-top: 50px;
        border-top: 1px solid #e5e7eb;
        padding-top: 15px;
        font-size: 9pt;
        color: #9ca3af;
        text-align: center;
    }
</style>
</head>
<body>

    <table class="header-table">
