rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users Collection ─────────────────────────────────────────────
    // Allow reading a user document for login (email+password lookup)
    match /users/{userId} {
      allow read: if true;    // Needed for Firestore-based password login
      allow write: if request.auth != null;
    }

    // ── Departments ───────────────────────────────────────────────────
    match /departments/{deptId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Manager Dashboards Config ─────────────────────────────────────
    match /managerDashboards/{deptId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Activity Logs ─────────────────────────────────────────────────
    match /activityLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // ── Notifications ─────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── System Config ─────────────────────────────────────────────────
    match /system_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Messages ──────────────────────────────────────────────────────
    match /messages/{msgId} {
      allow read, write: if request.auth != null;
    }
  }
}
